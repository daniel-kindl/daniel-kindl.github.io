{
  "name": "daniel-kindl-portfolio",
  "version": "2.0.0",
  "description": "Personal portfolio website showcasing projects and skills",
  "main": "index.html",
  "scripts": {
    "start": "live-server --port=8080 --open=/",
    "dev": "live-server --port=8080 --open=/",
    "format": "prettier --write \"**/*.{js,css,html,md}\"",
    "lint": "eslint src/scripts/**/*.js",
    "prefetch": "node scripts/fetch-github.js",
    "build": "node scripts/build.js"
  },
  "keywords": [
    "portfolio",
    "personal-website",
    "github-pages",
    "javascript",
    "html",
    "css"
  ],
  "author": "Daniel Kindl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/daniel-kindl/daniel-kindl.github.io.git"
  },
  "bugs": {
    "url": "https://github.com/daniel-kindl/daniel-kindl.github.io/issues"
  },
  "homepage": "https://daniel-kindl.github.io",
  "devDependencies": {
    "eslint": "^9.0.0",
    "live-server": "^1.2.2",
    "prettier": "^3.0.0"
  },
  "type": "module"
}
