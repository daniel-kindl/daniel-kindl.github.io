---
import ExternalLink from '@components/ui/ExternalLink.astro';
import { focusRingStyles } from '@lib/buttonStyles';
import { buildInfo } from '@lib/buildInfo';

const currentYear = new Date().getFullYear();
---

<footer class="mt-24 w-full border-t border-(--border-color) py-6">
  <div
    class="mx-auto flex max-w-5xl flex-col items-start justify-between gap-4 px-4 font-mono text-xs text-(--text-muted) sm:flex-row sm:items-baseline"
  >
    <div>
      <span
        >© {currentYear} Daniel Kindl | Built with <ExternalLink
          href="https://astro.build"
          class={`underline decoration-(--border-color) underline-offset-4 transition-colors hover:text-(--text-primary) hover:decoration-(--text-primary) ${focusRingStyles}`}
          >Astro</ExternalLink
        > · v{buildInfo.version}{buildInfo.commit && <> · {buildInfo.commit}</>}</span
      >
    </div>
    <div class="flex items-center gap-2 uppercase">
      <ExternalLink
        href="https://github.com/daniel-kindl"
        class={`min-h-[44px] min-w-[44px] justify-center transition-colors hover:text-(--text-primary) ${focusRingStyles}`}
        >GitHub</ExternalLink
      >
      <ExternalLink
        href="https://www.linkedin.com/in/kindldaniel/"
        class={`min-h-[44px] min-w-[44px] justify-center transition-colors hover:text-(--text-primary) ${focusRingStyles}`}
        >LinkedIn</ExternalLink
      >
      <a
        href="mailto:daniel.kindl@proton.me"
        class={`inline-flex min-h-[44px] min-w-[44px] items-center justify-center transition-colors hover:text-(--text-primary) ${focusRingStyles}`}
        >Email</a
      >
      <a
        href="/rss.xml"
        class={`inline-flex min-h-[44px] min-w-[44px] items-center justify-center transition-colors hover:text-(--text-primary) ${focusRingStyles}`}
        >RSS</a
      >
      <a
        href="/colophon"
        class={`inline-flex min-h-[44px] items-center justify-center px-1 transition-colors hover:text-(--text-primary) ${focusRingStyles}`}
        >Colophon</a
      >
    </div>
  </div>
</footer>
