---
import type { CollectionEntry } from 'astro:content';
import Typography from '../ui/Typography.astro';
import Tag from '../ui/Tag.astro';
import Button from '../ui/Button.astro';
import ExternalLink from '../ui/ExternalLink.astro';

interface Props {
  project: CollectionEntry<'projects'>;
  index: number;
  headingLevel?: 'h2' | 'h3';
  class?: string;
}

const { project, index, headingLevel = 'h2', class: className = '' } = Astro.props;
const isEven = index % 2 === 0;

const startYear = project.data.dates.start.getFullYear();
const endYear = project.data.dates.end?.getFullYear();
const timelineLabel = !project.data.dates.end
  ? `${startYear}–Present`
  : endYear === startYear
    ? `${startYear}`
    : `${startYear}–${endYear}`;
---

<article
  class={`grid grid-cols-1 md:grid-cols-12 gap-6 items-start border-b border-(--border-color) pb-12 last:border-0 ${isEven ? 'md:pt-4' : 'md:pt-16'} ${className}`}
>
  <div class={`md:col-span-7 flex flex-col ${isEven ? 'md:order-1' : 'md:order-2'}`}>
    <Typography variant="eyebrow"
      >Project {String(index + 1).padStart(2, '0')} · {project.data.role}</Typography
    >
    <Typography variant="h2" as={headingLevel} class="mb-4">
      {project.data.title}
    </Typography>
    <Typography variant="body" class="mb-6 max-w-xl text-(--text-muted)">
      {project.data.summary}
    </Typography>
    <div class="mb-6 flex flex-wrap gap-2">
      {project.data.stack.map((tech: string) => <Tag label={tech} />)}
    </div>
    <div class="flex gap-3">
      <Button href={`/projects/${project.id}`} variant="primary"> Read Case Study → </Button>
      {
        project.data.links?.repository && (
          <ExternalLink href={project.data.links.repository} variant="secondary">
            Repository
          </ExternalLink>
        )
      }
    </div>
  </div>

  <div
    class={`hidden md:block md:col-span-5 font-mono text-[10px] text-(--text-muted) uppercase border-l border-(--border-color) pl-4 h-full self-stretch ${isEven ? 'md:order-2' : 'md:order-1'}`}
  >
    <div class="space-y-1">
      <div>Status: {project.data.status}</div>
      <div>Timeline: {timelineLabel}</div>
      <div>Stack: {project.data.stack.length} technologies</div>
    </div>
  </div>
</article>
