---
import Tag from '../ui/Tag.astro';
import Button from '../ui/Button.astro';
import { slugify } from '@lib/slug';
import { formatDate } from '@lib/formatDate';
import { getReadingTime } from '@lib/readingTime';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'writing'>;
  headingLevel?: 'h2' | 'h3';
  class?: string;
}
const { post, headingLevel = 'h2', class: className = '' }: Props = Astro.props;
const TitleTag = headingLevel;
const readingTime = getReadingTime(post.body ?? '');
---

<article
  data-pagefind-ignore
  class={`border-b border-(--border-color) pb-8 last:border-0 ${className}`}
>
  <div class="flex flex-col gap-2">
    <p class="font-mono text-xs text-(--text-muted)">
      {formatDate(post.data.date)} · {readingTime} min read
    </p>
    <TitleTag class="text-xl font-bold tracking-tight text-(--text-primary) md:text-2xl">
      {post.data.title}
    </TitleTag>
    <p class="max-w-2xl text-sm leading-relaxed text-(--text-muted)">{post.data.summary}</p>
    {
      post.data.tags.length > 0 && (
        <div class="mt-2 flex flex-wrap gap-2">
          {post.data.tags.map((tag: string) => (
            <Tag label={tag} href={`/writing/tags/${slugify(tag)}`} />
          ))}
        </div>
      )
    }
    <div class="mt-4">
      <Button href={`/writing/${post.id}`} variant="secondary">Read Post →</Button>
    </div>
  </div>
</article>
