---
const navItems = [
  { href: '/projects', label: 'Projects' },
  { href: '/writing', label: 'Writing' },
  { href: '/about', label: 'About' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname === href || pathname.startsWith(`${href}/`);
---

<header class="mb-12 w-full border-b border-(--border-color) py-4">
  <div
    class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-x-4 gap-y-3 px-4 font-mono text-xs tracking-tight"
  >
    <a
      href="/"
      class="inline-flex min-h-[44px] items-center font-bold tracking-normal text-(--text-primary) uppercase transition-colors outline-none hover:underline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--text-primary)"
      >Daniel Kindl</a
    >

    <nav class="flex items-center gap-2">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class={`inline-flex min-h-[44px] min-w-[44px] items-center justify-center uppercase transition-colors outline-none focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--text-primary) ${
              isActive(item.href)
                ? 'text-(--text-primary) underline decoration-(--text-primary) underline-offset-4'
                : 'text-(--text-muted) hover:text-(--text-primary)'
            }`}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <button
      id="theme-toggle"
      class="inline-flex min-h-[44px] min-w-[44px] cursor-pointer items-center justify-center border border-(--text-muted) bg-(--bg-primary) px-3 text-(--text-primary) uppercase transition-colors outline-none focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-(--text-primary)"
      aria-label="Toggle color theme"
      aria-pressed="false"
    >
      <span class="theme-label-light">Light</span>
      <span class="theme-label-dark">Dark</span>
    </button>
  </div>
</header>

<script>
  function initializeThemeToggle() {
    const toggle = document.getElementById('theme-toggle');
    if (!toggle) return;

    // Remove existing listener if any to avoid stacking duplicates
    toggle.replaceWith(toggle.cloneNode(true));

    const activeToggle = document.getElementById('theme-toggle');
    activeToggle?.setAttribute(
      'aria-pressed',
      String(document.documentElement.getAttribute('data-theme') === 'dark'),
    );
    activeToggle?.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      activeToggle.setAttribute('aria-pressed', String(next === 'dark'));
    });
  }

  // Fire on standard load and after Astro swaps components during navigation
  initializeThemeToggle();
  document.addEventListener('astro:page-load', initializeThemeToggle);
</script>
