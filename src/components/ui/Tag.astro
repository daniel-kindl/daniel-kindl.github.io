---
interface Props {
  label: string;
  href?: string;
}
const { label, href }: Props = Astro.props;

const classes =
  'inline-flex min-h-[24px] items-center border border-(--text-muted) bg-(--bg-primary) px-2.5 py-1 font-mono text-[10px] tracking-tight text-(--text-muted) uppercase select-none';
---

{
  href ? (
    <a
      href={href}
      class={`${classes} transition-colors hover:border-(--text-primary) hover:text-(--text-primary)`}
    >
      {label}
    </a>
  ) : (
    <span class={classes}>{label}</span>
  )
}
