---
import '../styles/tokens.css';
import MainActionButton from '../components/islands/MainActionButton.svelte';
import ThemeToggle from '../components/islands/ThemeToggle.svelte';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Design System // Style Guide</title>

    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();

      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="selection:bg-accent selection:text-bg-primary mx-auto max-w-7xl px-6 py-24 md:px-16">
    <!-- HEADER LAYER -->
    <header
      class="border-border mb-24 flex flex-col items-start justify-between gap-6 border-b pb-12 sm:flex-row sm:items-end"
    >
      <div class="space-y-2">
        <h1
          class="font-display text-accent text-4xl leading-none font-bold tracking-tighter uppercase"
        >
          Swiss Typography
        </h1>
        <p class="text-text-secondary font-mono text-xs tracking-normal">
          [Astro 7 + Svelte 5] — Airy Minimal Architecture
        </p>
      </div>
      <div
        class="border-border flex items-center justify-between gap-8 self-stretch border-t pt-4 sm:self-auto sm:border-t-0 sm:pt-0"
      >
        <ThemeToggle client:load />
        <div class="text-accent font-mono text-xs font-bold tracking-widest">2026 // SPEC</div>
      </div>
    </header>

    <!-- SPECIFICATION GRID (Expanded spacing between macro blocks) -->
    <div class="space-y-32">
      <!-- SECTION 01: COLOR TOKENS (Fixed Label Contrast and Structure) -->
      <section class="grid grid-cols-1 items-start gap-12 lg:grid-cols-3 lg:gap-16">
        <div class="space-y-3">
          <h2 class="font-display text-accent text-xl font-bold tracking-tight uppercase">
            01 // Color Matrix
          </h2>
          <p class="text-text-secondary max-w-xs text-sm leading-relaxed">
            Dynamic range pairing optimized to decouple local elements from global backgrounds.
          </p>
        </div>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-3 lg:col-span-2">
          <!-- Accent Token Display Card -->
          <div
            class="border-border bg-accent group rounded-xs border p-6 transition-transform duration-300 hover:-translate-y-1"
          >
            <div class="bg-bg-primary/10 mb-4 h-24 border border-white/10"></div>
            <!-- Explicit color overrides applied here to guarantee absolute readability -->
            <p class="font-mono text-xs font-bold tracking-wide text-white">--color-accent</p>
            <p class="mt-1 font-mono text-[10px] text-white/70">Brand Main</p>
          </div>

          <!-- Secondary Background Token Display Card -->
          <div
            class="border-border bg-bg-secondary rounded-xs border p-6 transition-transform duration-300 hover:-translate-y-1"
          >
            <div class="bg-bg-primary border-border/10 mb-4 h-24 border"></div>
            <p class="text-text-primary font-mono text-xs font-bold tracking-wide">
              --bg-secondary
            </p>
            <p class="text-text-secondary mt-1 font-mono text-[10px]">Structural Fill</p>
          </div>

          <!-- Primary Text Token Display Card -->
          <div
            class="border-border bg-text-primary rounded-xs border p-6 transition-transform duration-300 hover:-translate-y-1"
          >
            <div class="bg-bg-primary mb-4 h-24"></div>
            <p class="text-bg-primary font-mono text-xs font-bold tracking-wide">--text-primary</p>
            <p class="text-bg-secondary mt-1 font-mono text-[10px]">High Contrast Type</p>
          </div>
        </div>
      </section>

      <!-- SECTION 02: TYPOGRAPHY SCALING -->
      <section
        class="border-border grid grid-cols-1 items-start gap-12 border-t pt-16 lg:grid-cols-3 lg:gap-16"
      >
        <div class="space-y-3">
          <h2 class="font-display text-accent text-xl font-bold tracking-tight uppercase">
            02 // Typography
          </h2>
          <p class="text-text-secondary max-w-xs text-sm leading-relaxed">
            Generous leading parameters and proportional layout density values.
          </p>
        </div>
        <div class="space-y-12 lg:col-span-2">
          <div class="space-y-2">
            <span class="text-text-secondary font-mono text-[10px] tracking-widest uppercase"
              >[ Display Scale ]</span
            >
            <p
              class="font-display text-text-primary text-4xl leading-[0.95] font-bold tracking-tighter uppercase"
            >
              Space Grotesk Heading
            </p>
          </div>
          <div class="space-y-2">
            <span class="text-text-secondary font-mono text-[10px] tracking-widest uppercase"
              >[ Body Scale ]</span
            >
            <p class="text-text-primary max-w-xl font-sans text-base leading-relaxed">
              IBM Plex Sans. Highly neutral neo-grotesque configuration explicitly adjusted with
              optimal text padding rules to maximize structural breathability without sacrificing
              technical data layout logic.
            </p>
          </div>
        </div>
      </section>

      <!-- SECTION 03: SYSTEM INTERACTIVES -->
      <section
        class="border-border grid grid-cols-1 items-start gap-12 border-t pt-16 lg:grid-cols-3 lg:gap-16"
      >
        <div class="space-y-3">
          <h2 class="font-display text-accent text-xl font-bold tracking-tight uppercase">
            03 // Motion & Nodes
          </h2>
          <p class="text-text-secondary max-w-xs text-sm leading-relaxed">
            Micro-scale physical responses validating interactivity smoothly.
          </p>
        </div>
        <div class="flex flex-col items-start gap-12 sm:flex-row sm:items-center lg:col-span-2">
          <MainActionButton client:load label="Commit Changes" />

          <div class="border-accent max-w-xs space-y-1 border-l pl-6">
            <p class="font-display text-text-primary text-base font-bold tracking-tight uppercase">
              Kinetic Response Anchor
            </p>
            <p class="text-text-secondary text-xs leading-relaxed">
              Hover animations use transform translation matrices rather than box shadow inflation
              to preserve white space cleanliness.
            </p>
          </div>
        </div>
      </section>
    </div>
  </body>
</html>
