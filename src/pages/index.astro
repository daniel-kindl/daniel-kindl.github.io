---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Container from '../components/ui/Container.astro';
import Typography from '../components/ui/Typography.astro';
import Button from '../components/ui/Button.astro';
import ProjectCard from '../components/portfolio/ProjectCard.astro';
import HeroGrid from '../components/portfolio/HeroGrid.svelte';

const projects = await getCollection('projects');
const features = projects.sort((a, b) => b.data.weight - a.data.weight).slice(0, 2);
---

<Layout title="Daniel Kindl — Software Engineer">
  <div
    class="relative flex min-h-[70vh] w-full items-center overflow-hidden border-b border-(--border-color)"
  >
    <HeroGrid client:load />
    <Container class="py-20">
      <Typography variant="eyebrow">Industrial Software Engineer</Typography>
      <Typography variant="h1" class="mb-6 max-w-3xl text-4xl leading-none font-black md:text-6xl">
        Building reliable <span class="text-(--text-muted)">industrial software</span> and modernizing
        legacy systems.
      </Typography>
      <Typography variant="body" class="mb-8 max-w-xl text-(--text-muted)">
        I design and ship C#/.NET and Delphi desktop solutions for industrial environments, with a
        focus on long-term maintainability, system integration, and safe migration from legacy code.
      </Typography>
      <div class="flex gap-4">
        <Button href="/projects" variant="primary">View Projects</Button>
        <Button href="/about" variant="secondary">About & CV</Button>
      </div>
    </Container>
  </div>

  <Container as="section" class="border-b border-(--border-color) py-20">
    <header class="mb-12 flex items-baseline justify-between">
      <div>
        <Typography variant="eyebrow">Selected Work</Typography>
        <Typography variant="h2">Recent Project Highlights</Typography>
      </div>
      <Button href="/projects" variant="secondary">All Projects →</Button>
    </header>

    <div class="space-y-12">
      {features.map((project, index) => <ProjectCard project={project} index={index} />)}
    </div>
  </Container>

  <Container as="section" class="py-20">
    <div class="max-w-3xl border border-(--border-color) bg-(--bg-primary) p-8 md:p-12">
      <Typography variant="eyebrow">Approach</Typography>
      <Typography variant="h3" class="mb-4"
        >Pragmatic modernization for production systems</Typography
      >
      <Typography variant="body" class="mb-6 text-(--text-muted)">
        My work combines delivery speed with engineering discipline: clear architecture boundaries,
        testable modules, and release pipelines that keep industrial software stable over time.
      </Typography>
      <Button href="/about" variant="primary">Read About & CV</Button>
    </div>
  </Container>
</Layout>
