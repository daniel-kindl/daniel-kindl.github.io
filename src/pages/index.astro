---
import Layout from '../layouts/Layout.astro';
import Container from '../components/ui/Container.astro';
import Typography from '../components/ui/Typography.astro';
import Button from '../components/ui/Button.astro';
import ProjectCard from '../components/portfolio/ProjectCard.astro';
import WritingPostCard from '../components/portfolio/WritingPostCard.astro';
import { getPublishedPosts, getSortedProjects } from '@lib/content';

const features = (await getSortedProjects()).slice(0, 2);
const recentPosts = (await getPublishedPosts()).slice(0, 2);
---

<Layout title="Daniel Kindl — Software Engineer">
  <div class="relative flex min-h-[70dvh] w-full items-center border-b border-(--border-color)">
    <Container class="py-20">
      <Typography
        variant="eyebrow"
        class="before:mr-1 before:text-(--text-muted) before:content-['['] after:ml-1 after:text-(--text-muted) after:content-[']']"
        >Software Engineer</Typography
      >
      <Typography variant="h1" class="mb-6 max-w-3xl text-4xl leading-none font-bold md:text-6xl">
        I design systems, <span class="text-(--text-muted)">then build them</span>.
      </Typography>
      <Typography variant="body" class="mb-8 max-w-xl text-(--text-muted)">
        I combine hands-on engineering experience with AI-assisted development to build software,
        ship it, and keep it running well over time.
      </Typography>
      <div class="flex gap-4">
        <Button href="/projects" variant="primary">View Projects</Button>
        <Button href="/about" variant="secondary">About & CV</Button>
      </div>
    </Container>
  </div>

  <Container as="section" class="border-b border-(--border-color) py-20">
    <header class="reveal mb-12 flex items-baseline justify-between">
      <div>
        <Typography variant="eyebrow">Selected Work</Typography>
        <Typography variant="h2">Recent Project Highlights</Typography>
      </div>
      <Button href="/projects" variant="secondary">All Projects →</Button>
    </header>

    <div class="space-y-12">
      {
        features.map((project, index) => (
          <ProjectCard
            project={project}
            index={index}
            headingLevel="h3"
            class={`reveal ${index === 1 ? 'delay-150' : ''}`}
          />
        ))
      }
    </div>
  </Container>

  <Container as="section" class="border-b border-(--border-color) py-20">
    <header class="reveal mb-12 flex items-baseline justify-between">
      <div>
        <Typography variant="eyebrow">Latest Writing</Typography>
        <Typography variant="h2">Recent Write-Ups</Typography>
      </div>
      <Button href="/writing" variant="secondary">All Writing →</Button>
    </header>

    <div class="space-y-12">
      {
        recentPosts.map((post, index) => (
          <WritingPostCard
            post={post}
            headingLevel="h3"
            class={`reveal ${index === 1 ? 'delay-150' : ''}`}
          />
        ))
      }
    </div>
  </Container>

  <Container as="section" class="py-20">
    <div class="reveal max-w-3xl border border-(--border-color) bg-(--bg-primary) p-8 md:p-12">
      <Typography variant="eyebrow">Approach</Typography>
      <Typography variant="h2" as="h3" class="mb-4">
        Pragmatic engineering across the stack
      </Typography>
      <Typography variant="body" class="mb-6 text-(--text-muted)">
        My work combines delivery speed with engineering discipline: clear architecture boundaries,
        testable modules, and release pipelines that hold up under real production use.
      </Typography>
      <Button href="/about" variant="primary">About & CV</Button>
    </div>
  </Container>
</Layout>

<script>
  function initScrollReveal() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const elements = document.querySelectorAll<HTMLElement>('.reveal');

    if (prefersReducedMotion || elements.length === 0) return;

    elements.forEach((el) => el.classList.add('reveal-hidden'));

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.remove('reveal-hidden');
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' },
    );

    elements.forEach((el) => observer.observe(el));
  }

  initScrollReveal();
  document.addEventListener('astro:page-load', initScrollReveal);
</script>
