---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Container from '../components/ui/Container.astro';
import Typography from '../components/ui/Typography.astro';
import Button from '../components/ui/Button.astro';
import ProjectCard from '../components/portfolio/ProjectCard.astro';

const projects = await getCollection('projects');
const features = projects.sort((a, b) => b.data.weight - a.data.weight).slice(0, 2);
---

<Layout title="Daniel Kindl — Software Engineer">
  <div class="relative flex min-h-[70vh] w-full items-center border-b border-(--border-color)">
    <Container class="py-20">
      <Typography
        variant="eyebrow"
        class="before:mr-1 before:text-(--text-muted) before:content-['['] after:ml-1 after:text-(--text-muted) after:content-[']']"
        >Software Engineer</Typography
      >
      <Typography variant="h1" class="mb-6 max-w-3xl text-4xl leading-none font-bold md:text-6xl">
        I design systems, <span class="text-(--text-muted)">then build them</span>.
      </Typography>
      <Typography variant="body" class="mb-8 max-w-xl text-(--text-muted)">
        I think through how software should be structured before writing any code — then combine
        hands-on engineering experience with AI-assisted development to build it, ship it, and keep
        it running well over time.
      </Typography>
      <div class="flex gap-4">
        <Button href="/projects" variant="primary">View Projects</Button>
        <Button href="/about" variant="secondary">About & CV</Button>
      </div>
    </Container>
  </div>

  <Container as="section" class="border-b border-(--border-color) py-20">
    <header class="mb-12 flex items-baseline justify-between">
      <div>
        <Typography variant="eyebrow">Selected Work</Typography>
        <Typography variant="h2">Recent Project Highlights</Typography>
      </div>
      <Button href="/projects" variant="secondary">All Projects →</Button>
    </header>

    <div class="space-y-12">
      {features.map((project, index) => <ProjectCard project={project} index={index} />)}
    </div>
  </Container>

  <Container as="section" class="py-20">
    <div class="max-w-3xl border border-(--border-color) bg-(--bg-primary) p-8 md:p-12">
      <Typography variant="eyebrow">Approach</Typography>
      <Typography variant="h3" class="mb-4">Pragmatic engineering across the stack</Typography>
      <Typography variant="body" class="mb-6 text-(--text-muted)">
        My work combines delivery speed with engineering discipline: clear architecture boundaries,
        testable modules, and release pipelines that keep software stable and maintainable over
        time.
      </Typography>
      <Button href="/about" variant="primary">About & CV</Button>
    </div>
  </Container>
</Layout>
