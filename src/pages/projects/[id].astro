---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/ui/Container.astro';
import Typography from '../../components/ui/Typography.astro';
import Tag from '../../components/ui/Tag.astro';
import Button from '../../components/ui/Button.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

// Safely resolve start date out of your content collection schema structure
const projectDate = project.data.dates?.start || project.data.dates;
---

<Layout title={`${project.data.title} — Technical Analysis`}>
  <article>
    <!-- TOP META HEADER -->
    <div class="border-b border-(--border-color) bg-(--bg-primary) py-12 md:py-20">
      <Container>
        <div class="mb-4">
          <Button href="/projects" variant="secondary" class="min-w-0! px-0!"
            >← Back to Stream</Button
          >
        </div>
        <Typography variant="eyebrow">
          SYSTEM_ID: {project.id} // WEIGHT: {project.data.weight}
        </Typography>
        <Typography variant="h1" class="mb-6 max-w-4xl">
          {project.data.title}
        </Typography>
        <div class="flex flex-wrap gap-2">
          {project.data.stack.map((tech: string) => <Tag label={tech} />)}
        </div>
      </Container>
    </div>

    <!-- SPECIFICATION GRID -->
    <div
      class="border-b border-(--border-color) bg-(--bg-primary) py-8 font-mono text-[11px] text-(--text-muted)"
    >
      <Container class="grid grid-cols-2 gap-6 md:grid-cols-4">
        <div>
          <div class="mb-1 font-bold text-(--text-primary) uppercase">[ROLE]</div>
          <div>{project.data.role}</div>
        </div>
        <div>
          <div class="mb-1 font-bold text-(--text-primary) uppercase">[TIMELINE]</div>
          <div>
            {
              projectDate
                ? new Date(projectDate).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                  })
                : 'OPERATIONAL'
            }
          </div>
        </div>
        <div>
          <div class="mb-1 font-bold text-(--text-primary) uppercase">[METRIC]</div>
          <div>BALANCED LAYER</div>
        </div>
        <div>
          <div class="mb-1 font-bold text-(--text-primary) uppercase">[STATUS]</div>
          <div>{project.data.status.toUpperCase()}</div>
        </div>
      </Container>
    </div>

    <!-- CONTENT BODY -->
    <Container class="py-12 md:py-16">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-12">
        <div class="prose max-w-none md:col-span-8">
          <Content />
        </div>

        <!-- SIDEBAR METRICS -->
        <aside
          class="sticky top-6 hidden h-fit space-y-4 border-l border-(--border-color) pl-6 font-mono text-[10px] text-(--text-muted) md:col-span-4 md:block"
        >
          <div>
            <div class="mb-1 font-bold text-(--text-primary)">// SYSTEM_SUMMARY</div>
            <p class="leading-relaxed">{project.data.summary}</p>
          </div>
          <div class="border-t border-(--border-color) pt-4">
            <div>[PIPELINE_VERIFICATION]</div>
            <div class="text-emerald-6xl text-emerald-600">✓ ALL CHECKS PASSED</div>
          </div>
        </aside>
      </div>
    </Container>
  </article>
</Layout>
