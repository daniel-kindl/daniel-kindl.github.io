---
import Layout from '../../../layouts/Layout.astro';
import Container from '../../../components/ui/Container.astro';
import Typography from '../../../components/ui/Typography.astro';
import Button from '../../../components/ui/Button.astro';
import WritingPostCard from '../../../components/portfolio/WritingPostCard.astro';
import { slugify } from '@lib/slug';
import { getPublishedPosts } from '@lib/content';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  const tagMap = new Map<string, { label: string; posts: typeof posts }>();

  for (const post of posts) {
    for (const tag of post.data.tags) {
      const slug = slugify(tag);
      const entry = tagMap.get(slug) ?? { label: tag, posts: [] };
      entry.posts.push(post);
      tagMap.set(slug, entry);
    }
  }

  return Array.from(tagMap.entries()).map(([slug, { label, posts }]) => ({
    params: { tag: slug },
    props: {
      tagLabel: label,
      // already sorted by date via getPublishedPosts()
      posts,
    },
  }));
}

const { tagLabel, posts } = Astro.props;
---

<Layout title={`${tagLabel} — Writing`} description={`Posts tagged “${tagLabel}”.`}>
  <Container as="main" class="py-12 md:py-20">
    <header class="mb-12">
      <Button href="/writing" variant="secondary" class="mb-4 min-w-0! px-0!"
        >← Back to Writing</Button
      >
      <Typography variant="eyebrow">Tag</Typography>
      <Typography variant="h1" class="mb-4">{tagLabel}</Typography>
      <Typography variant="body" class="max-w-2xl text-(--text-muted)">
        {posts.length}
        {posts.length === 1 ? 'post' : 'posts'} tagged "{tagLabel}".
      </Typography>
    </header>

    <div class="space-y-12">
      {posts.map((post) => <WritingPostCard post={post} />)}
    </div>
  </Container>
</Layout>
