---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Container from '../components/ui/Container.astro';
import Typography from '../components/ui/Typography.astro';
import WritingPostCard from '../components/portfolio/WritingPostCard.astro';

const posts = (await getCollection('writing')).filter(
  (post) => !post.data.draft || import.meta.env.DEV,
);
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Writing — Daniel Kindl"
  description="Technical notes and articles on software engineering."
>
  <Container as="main" class="py-12 md:py-20">
    <header class="mb-12">
      <Typography variant="eyebrow">Writing</Typography>
      <Typography variant="h1" class="mb-4">Notes on Building Software</Typography>
      <Typography variant="body" class="max-w-2xl text-(--text-muted)">
        Technical write-ups on the tools and systems I build.
      </Typography>
    </header>

    <div class="space-y-12">
      {sortedPosts.map((post) => <WritingPostCard post={post} />)}
      {
        sortedPosts.length === 0 && (
          <p class="text-sm text-(--text-muted)">No posts published yet — check back soon.</p>
        )
      }
    </div>
  </Container>
</Layout>
