---
import { ClientRouter } from 'astro:transitions';
import SEO from '../components/SEO.astro';
import ThemeScript from '../components/ThemeScript.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Software engineer specializing in industrial software modernization, desktop architecture, and robust system integration.',
  ogImage = '/assets/meta/og-default.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth motion-safe:scroll-smooth motion-reduce:scroll-auto">
  <head>
    <!-- Base Configuration Targets -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalURL} />
    <link
      rel="preload"
      href="/fonts/IBMPlexSans-VariableFont_wdth,wght.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/JetBrainsMono-VariableFont_wght.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <meta name="generator" content={Astro.generator} />

    <!-- Core Runtime Utilities & Engine Routing -->
    <ThemeScript />
    <ClientRouter />
    <SEO title={title} description={description} />

    <!-- Meta Indexing Titles -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph protocols -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />

    <!-- Twitter Platform Rules -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(ogImage, Astro.site)} />
  </head>
  <body
    class="flex min-h-screen flex-col bg-(--bg-primary) text-(--text-primary) antialiased selection:bg-emerald-500/30 selection:text-emerald-200"
  >
    <!-- Skip to main content link for screen-readers -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-emerald-500 focus:px-4 focus:py-2 focus:font-mono focus:text-xs focus:text-black"
    >
      [SKIP_TO_CONTENT]
    </a>

    <Header />

    <main id="main-content" class="mx-auto w-full max-w-7xl grow px-4 sm:px-6 lg:px-8">
      <slot />
    </main>

    <Footer />
  </body>
</html>
