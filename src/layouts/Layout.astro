---
import { ClientRouter } from 'astro:transitions';
import ThemeScript from '../components/ThemeScript.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Software engineer who designs systems, then builds them — combining hands-on engineering experience with AI-assisted development to ship and maintain production software.',
  ogImage = '/assets/meta/og-default.png',
}: Props = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="scroll-smooth motion-safe:scroll-smooth motion-reduce:scroll-auto">
  <head>
    <!-- Base Configuration Targets -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalURL} />
    <link
      rel="preload"
      href="/fonts/IBMPlexSans-VariableFont_wdth,wght.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/JetBrainsMono-VariableFont_wght.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Daniel Kindl — Writing"
      href="/rss.xml"
    />
    <meta name="generator" content={Astro.generator} />

    <!-- Core Runtime Utilities & Engine Routing -->
    <ThemeScript />
    <ClientRouter />

    <!-- Meta Indexing Titles -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph protocols -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />

    <!-- Twitter Platform Rules -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(ogImage, Astro.site)} />
  </head>
  <body
    class="flex min-h-screen flex-col bg-(--bg-primary) text-(--text-primary) antialiased selection:bg-(--accent)/30 selection:text-(--text-primary)"
  >
    <!-- Skip to main content link for screen-readers -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-(--accent) focus:px-4 focus:py-2 focus:font-mono focus:text-xs focus:text-black"
    >
      [SKIP_TO_CONTENT]
    </a>

    <Header />

    <main id="main-content" class="mx-auto w-full max-w-7xl grow px-4 sm:px-6 lg:px-8">
      <slot />
    </main>

    <Footer />

    <script>
      function initCodeCopyButtons() {
        const blocks = document.querySelectorAll<HTMLPreElement>('.prose pre');

        blocks.forEach((pre) => {
          if (pre.querySelector('.copy-code-button')) return;

          pre.classList.add('group', 'relative');

          const button = document.createElement('button');
          button.type = 'button';
          button.className =
            'copy-code-button absolute right-2 top-2 border border-(--border-color) bg-(--bg-primary) px-2 py-0.5 font-mono text-[10px] uppercase tracking-tight text-(--text-muted) opacity-0 transition-opacity duration-150 group-hover:opacity-100 hover:border-(--text-primary) hover:text-(--text-primary) focus-visible:opacity-100 outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--accent)';
          button.textContent = '[Copy]';
          button.setAttribute('aria-label', 'Copy code to clipboard');

          button.addEventListener('click', async () => {
            const code = pre.querySelector('code')?.textContent ?? '';
            try {
              await navigator.clipboard.writeText(code);
              button.textContent = '[Copied]';
            } catch {
              button.textContent = '[Failed]';
            }
            setTimeout(() => {
              button.textContent = '[Copy]';
            }, 1500);
          });

          pre.appendChild(button);
        });
      }

      initCodeCopyButtons();
      document.addEventListener('astro:page-load', initCodeCopyButtons);
    </script>
  </body>
</html>
